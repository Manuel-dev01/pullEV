# PullEV engine configuration. Copy to .env (gitignored) and fill in as needed.
# All values are OPTIONAL. The engine runs on the public Renaiss Index tier without them.

# Server
PORT=8080
# Comma-separated allowed web origins for CORS (production: your Vercel URL)
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Renaiss Index API (beta). Base URL override (default https://api.renaissos.com):
RENAISS_INDEX_URL=https://api.renaissos.com
# Partner-tier credentials (10k/day). Leave blank to use the public tier (10/day).
# NEVER commit real keys. This file is an example only.
RENAISS_API_KEY=
RENAISS_API_SECRET=

# Runtime valuation cache file (default cache/valuations.json, gitignored)
VALUATION_CACHE=cache/valuations.json
