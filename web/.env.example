# Base URL of the PullEV Go engine. Local dev default is http://localhost:8080.
# In production set this to the deployed engine URL (e.g. the Railway/Render URL).
ENGINE_URL=http://localhost:8080

# Grounded AI Pull Advisor (DeepSeek, OpenAI-compatible). Server-only, never
# exposed to the client. Leave blank to disable the advisor (it degrades gracefully).
DEEPSEEK_API_KEY=
